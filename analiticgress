function initMap(){
  if(!map){
    map=L.map('map',{zoomControl:true,attributionControl:false});
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:19,attribution:'© OSM'}).addTo(map);
    // init layer groups
    Object.keys(layers).forEach(k=>{layers[k]=L.layerGroup().addTo(map);});
  }
  refreshMap();
}

function clearMapLayers(){if(!map)return;Object.values(layers).forEach(l=>{if(l)l.clearLayers();});}

function refreshMap(){
  if(!map||!GF) return;
  Object.keys(layers).forEach(k=>{layers[k].clearLayers();});
  if(layerVisible.portals) drawPortals();
  if(layerVisible.mine) drawMyPortals();
  if(activePlayer&&layerVisible.player) drawPlayerRoute(activePlayer);
  if(activeSession&&layerVisible.session) drawSession(activeSession);
  if(activeSession&&layerVisible.context) drawSessionContext(activeSession);
  updateMapInfobar();
}

function drawPortals(){
  GF.portals.forEach(portal=>{
    if(!portal.lat||!portal.lng) return;
    const enl=portal.factions.ENL||0,res=portal.factions.RES||0;
    let color=enl>res?'#00e5a0':res>enl?'#00b4ff':'#ff9f00';
    if(enl===0&&res===0) color='#4a6a7a';
    const r=Math.max(5,Math.min(18,5+Math.sqrt(portal.count)*1.5));
    const circle=L.circleMarker([portal.lat,portal.lng],{radius:r,fillColor:color,color:'rgba(0,0,0,.4)',weight:1,fillOpacity:.7});
    circle.bindPopup(`<b>${esc(portal.name)}</b><br><span style="color:#00e5a0">ENL ${enl}</span> · <span style="color:#00b4ff">RES ${res}</span><br>Total: ${portal.count} acciones`);
    circle.on('click',()=>{circle.openPopup();});
    layers.portals.addLayer(circle);
  });
}

function drawMyPortals(){
  const myPortalEvents=GF.events.filter(e=>e.isMyEvent&&e.portal);
  const myPortals={};
  myPortalEvents.forEach(ev=>{
    if(!myPortals[ev.portal])myPortals[ev.portal]={name:ev.portal,attacks:0,neutralized:0,lat:null,lng:null};
    if(ev.actionType==='attack')myPortals[ev.portal].attacks++;
    if(ev.actionType==='neutralize')myPortals[ev.portal].neutralized++;
  });
  // Get coords from portals layer data
  GF.portals.forEach(p=>{if(myPortals[p.name]&&p.lat){myPortals[p.name].lat=p.lat;myPortals[p.name].lng=p.lng;}});
  Object.values(myPortals).forEach(p=>{
    if(!p.lat||!p.lng) return;
    const attacked=p.attacks>0||p.neutralized>0;
    const icon=L.divIcon({html:`<div style="width:14px;height:14px;border-radius:50%;background:${attacked?'#ff3355':'#00e5a0'};border:2px solid ${attacked?'#ff0000':'#00ffaa'};box-shadow:0 0 8px ${attacked?'#ff3355':'#00e5a0'}"></div>`,iconSize:[14,14],className:''});
    const m=L.marker([p.lat,p.lng],{icon});
    m.bindPopup(`<b>⭐ ${esc(p.name)}</b><br>Portal de HaidaMahalo<br>${attacked?`<span style="color:#ff3355">⚠ ${p.attacks} ataques · ${p.neutralized} neutralizados</span>`:'<span style="color:#00e5a0">Sin ataques</span>'}`);
    layers.mine.addLayer(m);
  });
}

function drawPlayerRoute(playerName){
  const P=GF.players.find(p=>p.name===playerName);if(!P) return;
  const col=P.faction==='ENL'?'#00e5a0':P.faction==='RES'?'#00b4ff':'#ff9f00';
  // Draw all speed segments chronologically
  const pEvs=P.rawEvents.filter(e=>e.kind==='presence'&&e.lat&&e.lng).sort((a,b)=>a.ts-b.ts);
  for(let i=1;i<pEvs.length;i++){
    const a=pEvs[i-1],b=pEvs[i];
    const dt=(b.ts-a.ts)/1000;
    if(dt<=0||dt>3600*4) continue;
    const distKm=haversine(a.lat,a.lng,b.lat,b.lng)/1000;
    if(distKm<0.01) continue;
    const kmh=distKm/(dt/3600);
    const lineCol=spdColor(spdClass(kmh));
    L.polyline([[a.lat,a.lng],[b.lat,b.lng]],{color:lineCol,weight:2,opacity:.7}).addTo(layers.player);
  }
  // Portal markers for this player
  const seen=new Set();
  pEvs.forEach(ev=>{
    if(seen.has(ev.portal)) return;seen.add(ev.portal);
    const icon=L.divIcon({html:`<div style="width:8px;height:8px;border-radius:50%;background:${col};border:1px solid rgba(0,0,0,.4)"></div>`,iconSize:[8,8],className:''});
    L.marker([ev.lat,ev.lng],{icon}).bindPopup(`<b>${esc(ev.portal)}</b><br>${playerName}`).addTo(layers.player);
  });
}

function drawSession(session){
  layers.session.clearLayers();
  const pts=session.portals.filter(p=>p.lat&&p.lng);
  if(pts.length<2) return;
  // Animated polyline
  const coords=pts.map(p=>[p.lat,p.lng]);
  const arch=session.dominantArch;
  const col=arch==='fielder'?'#00e5a0':arch==='ninja'?'#ff3355':arch==='builder'?'#00b4ff':arch==='linker'?'#ff9f00':'#aabbd0';
  L.polyline(coords,{color:col,weight:3,opacity:.9,dashArray:'6,4'}).addTo(layers.session);
  pts.forEach((p,i)=>{
    const icon=L.divIcon({html:`<div style="width:10px;height:10px;border-radius:50%;background:${col};border:2px solid rgba(255,255,255,.5);font-family:monospace;font-size:8px;color:#000;display:flex;align-items:center;justify-content:center">${i+1}</div>`,iconSize:[10,10],className:''});
    L.marker([p.lat,p.lng],{icon}).bindPopup(`<b>${i+1}. ${esc(p.name)}</b><br>${fmtDateShort(session.events.find(e=>e.portal===p.name)?.ts||session.startTs)}`).addTo(layers.session);
  });
  // Fit to session
  map.fitBounds(L.latLngBounds(coords),{padding:[40,40],maxZoom:14});
}

function drawSessionContext(session){
  layers.context.clearLayers();
  if(!session.centerLat) return;
  const RANGE=15000; // 15km
  const TWINDOW=30*60*1000; // ±30min
  GF.players.forEach(P=>{
    if(P.name===activePlayer) return;
    const inRange=P.rawEvents.filter(e=>{
      if(!e.lat||!e.lng) return false;
      if(Math.abs(e.ts-session.startTs)>TWINDOW&&Math.abs(e.ts-session.endTs)>TWINDOW) return false;
      return haversine(e.lat,e.lng,session.centerLat,session.centerLng)<RANGE;
    });
    if(!inRange.length) return;
    const col=P.faction==='ENL'?'#00e5a080':P.faction==='RES'?'#00b4ff80':'#ff9f0080';
    inRange.forEach(ev=>{
      const icon=L.divIcon({html:`<div style="width:6px;height:6px;border-radius:50%;background:${col}"></div>`,iconSize:[6,6],className:''});
      L.marker([ev.lat,ev.lng],{icon}).bindPopup(`<b>${esc(P.name)}</b> (contexto)<br>${esc(ev.portal||'')}<br>${fmtDateShort(ev.ts)}`).addTo(layers.context);
    });
  });
}

function toggleLayer(name){
  layerVisible[name]=!layerVisible[name];
  if(map&&GF) refreshMap();
}

function fitAll(){
  if(!map||!GF) return;
  const pts=GF.portals.filter(p=>p.lat&&p.lng).map(p=>[p.lat,p.lng]);
