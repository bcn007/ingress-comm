function classifyEvent(text){
  const t=(text||'').normalize('NFD').replace(/[\u0300-\u036f]/g,'').toLowerCase();
  if(!t) return 'unknown';
  if(/(attack|attacked|destroy|destroyed|neutraliz|neutralis|damag|resonator destroyed|mod destroyed|link destroyed|field destroyed|ada refactor|jarvis virus|xmp|ultra strike|us attack|killed|removed)/i.test(t)) return 'attack';
  if(/(recharg|recharged|recarg)/i.test(t)) return 'unknown';
  if(/(captur|captured|deployed|deploy|resonator deployed|upgrade|upgraded|installed|install mod|mod installed|linked|created a link|link created|created a control field|control field created|created field|field created)/i.test(t)) return 'presence';
  return 'unknown';
}
function ekIcon(k){return k==='presence'?'📍':k==='attack'?'💥':'❓';}
function haversine(lat1,lng1,lat2,lng2){const R=6371008.8,r=d=>d*Math.PI/180;const dLat=r(lat2-lat1),dLng=r(lng2-lng1);const a=Math.sin(dLat/2)**2+Math.cos(r(lat1))*Math.cos(r(lat2))*Math.sin(dLng/2)**2;return 2*R*Math.asin(Math.sqrt(a));}
function spdClass(kmh){if(kmh>120)return 'r';if(kmh>80)return 'o';if(kmh>45)return 'y';return 'ok';}
function spdEmoji(cls){return{ok:'🟢',y:'🟡',o:'🟠',r:'🔴'}[cls]||'🟢';}
function spdColor(cls){return{ok:'#00e5a0',y:'#ffe45c',o:'#ff8c1a',r:'#ff2d2d'}[cls]||'#00e5a0';}

function computeSpeedSegments(P){
  const pEvs=P.rawEvents.filter(e=>e.kind==='presence'&&e.lat&&e.lng);
  const segs=[];
  for(let i=1;i<pEvs.length;i++){
    const a=pEvs[i-1],b=pEvs[i];
    const dt=(b.ts-a.ts)/1000;
    if(dt<=0||dt>3600*4) continue;
    if(Math.abs(a.lat-b.lat)<0.000001&&Math.abs(a.lng-b.lng)<0.000001) continue;
    const distKm=haversine(a.lat,a.lng,b.lat,b.lng)/1000;
    if(distKm<0.01) continue;
    const kmh=distKm/(dt/3600);
    segs.push({fromPortal:a.portal,toPortal:b.portal,fromTs:a.ts,toTs:b.ts,distKm,dt,kmh,cls:spdClass(kmh),fromLat:a.lat,fromLng:a.lng,toLat:b.lat,toLng:b.lng});
  }
  segs.sort((a,b)=>b.kmh-a.kmh);
  P.speedSegments=segs;
  P.speedTotalKm=segs.reduce((s,x)=>s+x.distKm,0);
  P.speedMaxKmh=segs[0]?.kmh||0;
  P.speedMaxClass=segs[0]?spdClass(segs[0].kmh):'ok';
  const valid=segs.filter(s=>s.dt>0);
  P.speedAvgKmh=valid.length?valid.reduce((s,x)=>s+x.kmh,0)/valid.length:0;
}

