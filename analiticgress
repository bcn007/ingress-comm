}

function renderPlayerFicha(name){
  const P=GF?.players.find(p=>p.name===name);
  document.getElementById('playerFichaEmpty').style.display=P?'none':'block';
  document.getElementById('playerFicha').style.display=P?'block':'none';
  if(!P) return;
  const ad=P.archetypeData||{icon:'⚙️',label:'Generalista',cls:'arch-generalist',desc:''};
  const fCol=f=>f==='ENL'?'var(--enl)':f==='RES'?'var(--res)':'var(--unk)';
  const color=fCol(P.faction);
  const firstDate=P.firstTs?new Date(P.firstTs).toLocaleDateString('es-ES'):'-';
  const lastDate=P.lastActiveTs?new Date(P.lastActiveTs).toLocaleDateString('es-ES'):'-';
  const pats=P.patterns||{};
  const patChips=Object.values(pats).filter(Boolean).map(pat=>pat.label?`<span class="chip" title="${esc(pat.desc||'')}">${esc(pat.label)}</span>`:'').join('');

  // Sessions HTML
  const sessHTML=P.sessions&&P.sessions.length?P.sessions.slice().reverse().map(sess=>{
    const fc=P.faction==='ENL'?'enl':'res';
    const isAct=activeSession&&activeSession.id===sess.id;
    return `<div class="session-card ${fc}${isAct?' active':''}" onclick="selectSession('${esc(name)}','${esc(sess.id)}')">
      <div class="sess-header">
        <div class="sess-time">${fmtDateShort(sess.startTs)} → ${fmtDateShort(sess.endTs)}</div>
        <div class="sess-dur">${sess.durationMin}min</div>
      </div>
      <div class="sess-stats">
        <span><span class="sess-stat-val">${sess.portals.length}</span> portales</span>
        <span><span class="sess-stat-val">${sess.events.length}</span> eventos</span>
        ${sess.totalMU>0?`<span><span class="sess-stat-val">${sess.totalMU}</span> MU</span>`:''}
        <span class="spd ${sess.spdCls}">${spdEmoji(sess.spdCls)}</span>
        <span class="archetype ${archetypeMap[sess.dominantArch]?.cls||'arch-generalist'}" style="font-size:8px">${archetypeMap[sess.dominantArch]?.icon||'⚙️'}</span>
      </div>
      ${sess.zone?`<div class="sess-portals">📌 ${esc(sess.zone)}</div>`:''}
    </div>`;
  }).join(''):`<div style="color:var(--text-dim);font-size:11px">Sin sesiones detectadas.</div>`;

  // Hour chart
  const hours=Array.from({length:24},(_,h)=>P.hourActivity[h]||0);
  const maxH=Math.max(...hours,1);
  const hChart=hours.map((v,h)=>`<div class="h-bar" style="height:${Math.max(2,Math.round(v/maxH*50))}px;background:${color};opacity:${.3+.7*(v/maxH)}" data-tip="${h}h: ${v}"></div>`).join('');

  // Top speed segs
  const topSegs=P.speedSegments.slice(0,4);

  // Coord panel
  const coordHTML=P.coordWith&&P.coordWith.length?`
    <div class="s-title">🤝 COORDINACIÓN</div>
    ${P.coordWith.slice(0,5).map(c=>{const cp=GF.players.find(p=>p.name===c.partner);const pf=cp?.faction==='ENL'?'enl':cp?.faction==='RES'?'res':'unk';const pCol=cp?.faction==='ENL'?'var(--enl)':cp?.faction==='RES'?'var(--res)':'var(--unk)';return `<div class="coord-row"><span style="font-family:'Orbitron',monospace;font-size:10px;color:${pCol};width:110px;flex-shrink:0">${esc(c.partner)}</span><div class="coord-bar"><div class="coord-fill" style="width:${pct(c.count,P.coordWith[0].count)}%;background:${pCol}"></div></div><span style="font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--text-dim)">${c.count} ev · ${c.portals}p</span></div>`;}).join('')}`:'';

  document.getElementById('playerFicha').innerHTML=`
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap">
      <span style="font-family:'Orbitron',monospace;font-size:16px;font-weight:900;color:${color}">${esc(name)}${name===MY_AGENT?'<span class="me-star">★</span>':''}</span>
      <span class="archetype ${ad.cls}">${ad.icon} ${esc(ad.label)}</span>
    </div>
    ${P.tacticalSummary?`<div class="tact-summary">${esc(P.tacticalSummary)}</div>`:''}
    <div class="chip-wrap">${patChips}</div>
    <div class="p-stats">
      <div class="p-stat"><div class="p-stat-lbl">ACCIONES</div><div class="p-stat-val" style="color:${color}">${P.count}</div></div>
      <div class="p-stat"><div class="p-stat-lbl">MU</div><div class="p-stat-val" style="color:var(--enl)">${P.totalMU.toLocaleString()}</div></div>
      <div class="p-stat"><div class="p-stat-lbl">DÍAS ACTIVO</div><div class="p-stat-val" style="color:${color}">${P.daysActive.size}</div></div>
      <div class="p-stat"><div class="p-stat-lbl">SESIONES</div><div class="p-stat-val" style="color:${color}">${P.sessions?.length||0}</div></div>
      <div class="p-stat"><div class="p-stat-lbl">VEL.MÁX</div><div class="p-stat-val"><span class="spd ${P.speedMaxClass||'ok'}" style="font-size:12px">${P.speedMaxKmh.toFixed(0)}</span></div></div>
      <div class="p-stat"><div class="p-stat-lbl">PORTAL TOP</div><div class="p-stat-val" style="font-size:10px;color:${color}">${P.topPortal?esc(P.topPortal[0]).slice(0,14)+'…':'-'}</div></div>
    </div>

    ${coordHTML}

    <div class="s-title" style="margin-top:10px">SESIONES DE JUEGO <span style="font-size:8px;font-weight:normal;letter-spacing:0">(click → ver en mapa)</span></div>
    <div class="session-list" style="max-height:280px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--border) transparent">
      ${sessHTML}
    </div>

    ${topSegs.length?`
    <div class="s-title" style="margin-top:10px">🚀 TOP VELOCIDADES</div>
    <div class="speed-panel">
      ${topSegs.map(s=>`<div class="seg-row"><span class="spd ${s.cls}" style="flex-shrink:0">${spdEmoji(s.cls)}</span><div class="seg-main"><div class="seg-portals">${esc(s.fromPortal||'?')} → ${esc(s.toPortal||'?')}</div><div class="seg-meta">${s.distKm.toFixed(2)}km · ${fmtDur(s.dt)}</div></div><div class="seg-kmh" style="color:var(--spd-${s.cls})">${s.kmh.toFixed(0)}<span style="font-size:8px"> km/h</span></div></div>`).join('')}
    </div>`:''}

    <div class="s-title">ACTIVIDAD HORARIA</div>
    <div class="hour-chart">${hChart}</div>
    <div class="h-labels">${[0,4,8,12,16,20,23].map(h=>`<span>${pad(h)}h</span>`).join('')}</div>

    ${GF.myAttacks[name]?`
    <div class="s-title" style="margin-top:10px;color:var(--danger)">⚠ ATAQUES A MIS PORTALES</div>
    <div class="attack-panel">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:8px">
        <div class="p-stat"><div class="p-stat-lbl">EVENTOS</div><div class="p-stat-val" style="color:var(--danger);font-size:16px">${GF.myAttacks[name].timestamps.length}</div></div>
        <div class="p-stat"><div class="p-stat-lbl">NEUTR.</div><div class="p-stat-val" style="color:var(--danger);font-size:16px">${GF.myAttacks[name].portalsNeutralized}</div></div>
        <div class="p-stat"><div class="p-stat-lbl">LINKS</div><div class="p-stat-val" style="color:var(--unk);font-size:16px">${GF.myAttacks[name].linksDestroyed}</div></div>
      </div>
      ${Object.entries(GF.myAttacks[name].portalsHit).sort((a,b)=>b[1]-a[1]).slice(0,4).map(([p,n])=>`<div class="def-row"><div class="def-portal">${esc(p)}</div><div class="def-time">${n}x</div></div>`).join('')}
    </div>`:''} `;
}

function selectSession(playerName,sessionId){
  const P=GF?.players.find(p=>p.name===playerName);if(!P) return;
  const sess=P.sessions.find(s=>s.id===sessionId);if(!sess) return;
  activeSession=sess;
  renderPlayerFicha(playerName); // refresh to show active state
  if(map&&GF){
    if(layerVisible.session) drawSession(sess);
    if(layerVisible.context) drawSessionContext(sess);
    updateMapInfobar();
  }
}

function flyToPortal(name){
  const p=GF?.portals.find(x=>x.name===name);
  if(p&&p.lat&&map) map.setView([p.lat,p.lng],16);
}

// ============================================================
// UI HELPERS
// ============================================================
function switchPTab(btn,tabId){
  document.querySelectorAll('.ptab').forEach(b=>b.classList.remove('on'));
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('on'));
  btn.classList.add('on');
  document.getElementById(tabId).classList.add('on');
}

function setAgentFilter(filter,btn){
  agentFilter=filter;
  document.querySelectorAll('#tabAgents .btn-small').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  if(GF) renderPlayers(filter);
}

// ============================================================
// UTILS
// ============================================================
function pct(v,t){return t?Math.round(v/t*100):0;}
function pad(n){return String(n).padStart(2,'0');}
function esc(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function fmtDur(sec){sec=Number(sec)||0;if(sec<60)return Math.round(sec)+'s';if(sec<3600)return Math.round(sec/60)+'min';return Math.floor(sec/3600)+'h'+Math.round((sec%3600)/60)+'m';}
function fmtDateShort(ts){if(!ts)return'—';try{return new Date(ts).toLocaleString('es-ES',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'});}catch{return'—';}}
</script>
