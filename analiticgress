const sortStateP={};const sortStatePort={};
function makeSortable(tableId,data,cols,rowFn,ss){
  const tbl=document.getElementById(tableId);if(!tbl)return;
  const renderT=()=>{
    let sorted=[...data];
    if(ss.col!=null){sorted.sort((a,b)=>{const av=cols[ss.col].val(a),bv=cols[ss.col].val(b);const cmp=typeof av==='number'?av-bv:String(av).localeCompare(String(bv));return ss.dir==='asc'?cmp:-cmp;});}
    const thead=cols.map((c,i)=>{const cls=ss.col===i?(ss.dir==='asc'?'sort-asc':'sort-desc'):'';return `<th class="${cls}" data-col="${i}">${c.label}<span class="sa"></span></th>`;}).join('');
    tbl.innerHTML=`<thead><tr>${thead}</tr></thead><tbody>${sorted.map((row,i)=>rowFn(row,i,sorted)).join('')}</tbody>`;
    tbl.querySelectorAll('thead th').forEach(th=>{th.addEventListener('click',()=>{const col=parseInt(th.dataset.col);if(ss.col===col)ss.dir=ss.dir==='asc'?'desc':'asc';else{ss.col=col;ss.dir='desc';}renderT();});});
  };
  renderT();
}

