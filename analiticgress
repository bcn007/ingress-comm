// SESSION BUILDER
// ============================================================
function buildSessions(rawEvents){
  if(!rawEvents||!rawEvents.length) return [];
  const sorted=[...rawEvents].sort((a,b)=>a.ts-b.ts);
  const sessions=[];
  let cur={events:[sorted[0]]};
  for(let i=1;i<sorted.length;i++){
    const ev=sorted[i];
    const prev=sorted[i-1];
    if(ev.ts-prev.ts>SESSION_GAP){
      sessions.push(finalizeSession(cur));
      cur={events:[ev]};
    }else{
      cur.events.push(ev);
    }
  }
  sessions.push(finalizeSession(cur));
  return sessions;
}

function finalizeSession(cur){
  const evs=cur.events;
  const startTs=evs[0].ts;
  const endTs=evs[evs.length-1].ts;
  const durationMin=Math.round((endTs-startTs)/60000);
  // Portal list ordered, with coords
  const portalMap={};
  evs.forEach(ev=>{if(ev.portal&&ev.lat){portalMap[ev.portal]={lat:ev.lat,lng:ev.lng};}});
  // Ordered unique portals
  const portalsOrdered=[];
  const seen=new Set();
  evs.forEach(ev=>{if(ev.portal&&!seen.has(ev.portal)){seen.add(ev.portal);portalsOrdered.push({name:ev.portal,lat:ev.lat||portalMap[ev.portal]?.lat,lng:ev.lng||portalMap[ev.portal]?.lng});}});
  const actions={capture:0,deploy:0,link:0,field:0,destroy:0,destroyLink:0,destroyField:0,other:0};
  let mu=0;
  evs.forEach(ev=>{actions[ev.actionType]=(actions[ev.actionType]||0)+1;if(ev.mu)mu+=ev.mu;});
  // Dominant pattern
  const total=evs.length||1;
  const fieldR=(actions.field||0)/total,deployR=(actions.deploy||0)/total,destroyR=(actions.destroy||0)/total,capR=(actions.capture||0)/total,linkR=(actions.link||0)/total;
  let arch='generalist';
  if(fieldR>0.2) arch='fielder';
  else if(destroyR>0.25&&capR>0.1) arch='ninja';
  else if(deployR>0.45) arch='builder';
  else if(linkR>0.3&&fieldR<0.08) arch='linker';
  else if(deployR>0.3&&destroyR<0.05) arch='defender';
  // Speed within session
  let maxKmh=0;
  const pEvs=evs.filter(e=>e.kind==='presence'&&e.lat&&e.lng);
  for(let i=1;i<pEvs.length;i++){
    const a=pEvs[i-1],b=pEvs[i];
    const dt=(b.ts-a.ts)/1000;
    if(dt<=0||dt>3600*4) continue;
    const distKm=haversine(a.lat,a.lng,b.lat,b.lng)/1000;
    if(distKm<0.01) continue;
    const kmh=distKm/(dt/3600);
    if(kmh>maxKmh) maxKmh=kmh;
  }
  // Centroid
  const withCoords=portalsOrdered.filter(p=>p.lat);
  const centerLat=withCoords.length?withCoords.reduce((s,p)=>s+p.lat,0)/withCoords.length:null;
  const centerLng=withCoords.length?withCoords.reduce((s,p)=>s+p.lng,0)/withCoords.length:null;
  // Zone
  const zones={};evs.forEach(ev=>{if(ev.zone)zones[ev.zone]=(zones[ev.zone]||0)+1;});
  const zone=Object.entries(zones).sort((a,b)=>b[1]-a[1])[0]?.[0]||null;
  return{startTs,endTs,durationMin,events:evs,portals:portalsOrdered,actions,totalMU:mu,dominantArch:arch,maxKmh,spdCls:spdClass(maxKmh),centerLat,centerLng,zone,id:`${startTs}`};
}

