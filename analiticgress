function computeCoordination(allPlayers,allEvents){
  const WINDOW=15*60*1000;const portalEvs={};
  allEvents.forEach(ev=>{if(!ev.agent||!ev.portal||ev.isMyEvent)return;if(AGENT_BLACKLIST.has(ev.agent.toLowerCase()))return;if(!portalEvs[ev.portal])portalEvs[ev.portal]=[];portalEvs[ev.portal].push(ev);});
  const pairCounts={};
  Object.values(portalEvs).forEach(evs=>{evs.sort((a,b)=>a.ts-b.ts);for(let i=0;i<evs.length;i++){for(let j=i+1;j<evs.length;j++){if(evs[j].ts-evs[i].ts>WINDOW)break;const a=evs[i].agent,b=evs[j].agent;if(a===b)continue;const key=[a,b].sort().join('|||');if(!pairCounts[key])pairCounts[key]={agents:[a,b],count:0,portals:new Set()};pairCounts[key].count++;pairCounts[key].portals.add(evs[i].portal);}}});
  const playerMap={};allPlayers.forEach(P=>{playerMap[P.name]=P;P.coordWith=[];});
  Object.values(pairCounts).forEach(pair=>{if(pair.count<3)return;const[nA,nB]=pair.agents;if(playerMap[nA])playerMap[nA].coordWith.push({partner:nB,count:pair.count,portals:pair.portals.size});if(playerMap[nB])playerMap[nB].coordWith.push({partner:nA,count:pair.count,portals:pair.portals.size});});
  allPlayers.forEach(P=>{P.coordWith.sort((a,b)=>b.count-a.count);if(P.coordWith.length>0){const top=P.coordWith[0];if(P.patterns)P.patterns.coordination={label:`🤝 Opera con ${top.partner}`,desc:`Co-actividad en ${top.portals} portales. ${top.count} coincidencias en 15min.`,top};if(P.tacticalSummary)P.tacticalSummary+=` · 🤝 Coordinación detectada`;}});
}

// ============================================================
// PARSE ALL
// ============================================================
function parseAll(texts,names){
  const seenEvents=new Set();
  let events=[],fileMetas=[];
  texts.forEach((txt,i)=>{
    const{meta,evs}=parseFile(txt,names[i]);
    fileMetas.push(meta);
    evs.forEach(ev=>{const k=`${ev.ts}|${ev.faction}|${ev.msg}`;if(!seenEvents.has(k)){seenEvents.add(k);events.push(ev);}});
  });
  events.sort((a,b)=>a.ts-b.ts);

  // Build players with sessions
  const playerMap={};
  events.forEach(ev=>{
    if(!ev.agent||AGENT_BLACKLIST.has(ev.agent.toLowerCase())) return;
    if(!playerMap[ev.agent]) playerMap[ev.agent]=initPlayer(ev.agent,ev.faction);
    const P=playerMap[ev.agent];
    if(P.faction==='UNK'&&ev.faction!=='UNK') P.faction=ev.faction;
    if(ev.portal) P.portalFreq[ev.portal]=(P.portalFreq[ev.portal]||0)+1;
    const h=new Date(ev.ts).getHours();P.hourActivity[h]=(P.hourActivity[h]||0)+1;
    const dow=new Date(ev.ts).getDay();P.dowActivity[dow]=(P.dowActivity[dow]||0)+1;
    if(ev.zone) P.zones[ev.zone]=(P.zones[ev.zone]||0)+1;
    if(ev.mu>0) P.totalMU+=ev.mu;
    if(P.lastTs&&(ev.ts-P.lastTs)<30*60*1000) P.sessionMs+=ev.ts-P.lastTs;
    else if(P.lastTs) P.sessions_count++;
    P.lastTs=ev.ts;if(!P.firstTs)P.firstTs=ev.ts;P.lastActiveTs=ev.ts;
    P.daysActive.add(new Date(ev.ts).toISOString().slice(0,10));
    if(ev.actionType==='deploy'||ev.actionType==='capture') if(ev.portal) P.deployedPortals[ev.portal]=(P.deployedPortals[ev.portal]||0)+1;
    const kind=classifyEvent(ev.msg);
    ev.kind=kind;ev.mu=ev.mu||0;
    P.rawEvents.push({ts:ev.ts,portal:ev.portal||'',lat:ev.lat,lng:ev.lng,actionType:ev.actionType,kind,msg:ev.msg,mu:ev.mu||0});
    P.eventKinds[kind]=(P.eventKinds[kind]||0)+1;
    P.count++;
    P.actions[ev.actionType]=(P.actions[ev.actionType]||0)+1;
  });

  const allPlayers=Object.values(playerMap);
  allPlayers.forEach(P=>{
    P.sessions_count=Math.max(1,P.sessions_count);
    P.avgSessionMin=P.sessionMs>0?Math.round(P.sessionMs/60000/P.sessions_count):0;
    P.topPortal=Object.entries(P.portalFreq).sort((a,b)=>b[1]-a[1])[0];
    P.topZone=Object.entries(P.zones).sort((a,b)=>b[1]-a[1])[0];
    // Build sessions
    P.sessions=buildSessions(P.rawEvents);
    computeSpeedSegments(P);
    computePatterns(P,events);
  });
  computeCoordination(allPlayers,events);

  const totalMsg=fileMetas.reduce((a,m)=>a+(m.total||0),0);
  const dupCount=Math.max(0,totalMsg-events.length);
  const minDate=fileMetas.reduce((a,m)=>m.rangeFrom<a?m.rangeFrom:a,fileMetas[0]?.rangeFrom||'');
  const maxDate=fileMetas.reduce((a,m)=>m.rangeTo>a?m.rangeTo:a,fileMetas[0]?.rangeTo||'');

  return{events,players:allPlayers.sort((a,b)=>b.count-a.count),meta:{totalMsg,dupCount,minDate,maxDate,fileCount:names.length}};
}

function initPlayer(name,faction){
  return{name,faction,count:0,actions:{capture:0,deploy:0,link:0,field:0,destroy:0,destroyLink:0,destroyField:0,other:0},portalFreq:{},hourActivity:{},dowActivity:{},zones:{},deployedPortals:{},rawEvents:[],eventKinds:{presence:0,attack:0,unknown:0},speedSegments:[],speedAvgKmh:0,speedMaxKmh:0,speedMaxClass:'ok',speedTotalKm:0,totalMU:0,sessions_count:1,sessionMs:0,lastTs:null,firstTs:null,lastActiveTs:null,daysActive:new Set(),topPortal:null,topZone:null,avgSessionMin:0,sessions:[],patterns:{},archetypeData:archetypeMap.generalist,tacticalSummary:'',coordWith:[]};
}

function parseFile(txt,fname){
  const lines=txt.split('\n');const meta={filename:fname,total:0,rangeFrom:'',rangeTo:''};const evs=[];
  for(const l of lines){const tm=l.match(/Total mensajes:\s*(\d+)/);if(tm)meta.total=parseInt(tm[1]);const rm=l.match(/Rango:\s*([\d\- :]+)\s*-->\s*([\d\- :]+)/);if(rm){meta.rangeFrom=rm[1].trim();meta.rangeTo=rm[2].trim();}}
  const evRe=/^\[(\d{4}-\d{2}-\d{2} \d{2}:\d{2}:\d{2})\] \[(ENL|RES|\?\?\?)\] (.+)$/;const porRe=/→ Portal: (.+?) \(([\d.]+),([\d.]+)\)/;let cur=null;
  for(const l of lines){
    const em=l.match(evRe);
    if(em){const[,tsStr,fRaw,msg]=em;const faction=fRaw==='???'?'UNK':fRaw;const ts=new Date(tsStr+' UTC').getTime();const parsed=parseMsg(msg);cur={ts,faction,msg,...parsed};evs.push(cur);}
    else if(cur&&l.includes('→ Portal:')){const pm=l.match(porRe);if(pm){if(!cur.portal)cur.portal=pm[1].trim();cur.lat=parseFloat(pm[2]);cur.lng=parseFloat(pm[3]);cur.zone=extractZone(pm[1]);}}
  }
  return{meta,evs};
}

function parseMsg(msg){
  if(msg.startsWith('Your ')){const aM=msg.match(/^Your Portal (.+?) \(.*?\) is under attack by (.+)$/),nM=msg.match(/^Your Portal (.+?) \(.*?\) neutralized by (.+)$/),lM=msg.match(/^Your Link .+? to .+? destroyed by (.+)$/),fM=msg.match(/^Your Field .+? destroyed by (.+)$/);let at='kinetic',pt=null,att=null;if(aM){at='attack';pt=aM[1].trim();att=aM[2].trim();}else if(nM){at='neutralize';pt=nM[1].trim();att=nM[2].trim();}else if(lM){at='destroyLink';att=lM[1].trim();}else if(fM){at='destroyField';att=fM[1].trim();}return{agent:'Your',actionType:at,portal:pt,mu:0,isMyEvent:true,attacker:att,zone:null};}
  const agM=msg.match(/^Agent (.+?) destroyed the Resistance (Link|Control Field) .+/);if(agM){const a=cleanA(agM[1]);if(AGENT_BLACKLIST.has(a.toLowerCase()))return NE();return{agent:a,actionType:agM[2]==='Link'?'destroyLink':'destroyField',portal:null,mu:0,isMyEvent:false,attacker:null,zone:null};}
  const fM=msg.match(/^(?:Enlightened agent |Resistance agent )?(.+?) created a Control Field @(.+?) \(.*?\) \+(\d+) MUs/);if(fM)return V(cleanA(fM[1]),'field',fM[2].trim(),parseInt(fM[3])||0);
  const cM=msg.match(/^(?:Enlightened agent |Resistance agent )?(.+?) captured (.+?) \(/);if(cM)return V(cleanA(cM[1]),'capture',cM[2].trim(),0);
  const dM=msg.match(/^(?:Enlightened agent |Resistance agent )?(.+?) deployed a Resonator on (.+?) \(/);if(dM)return V(cleanA(dM[1]),'deploy',dM[2].trim(),0);
  const lM=msg.match(/^(?:Enlightened agent |Resistance agent )?(.+?) linked (?:from )?(.+?) \(.*?\) to /);if(lM)return V(cleanA(lM[1]),'link',lM[2].trim(),0);
  const rM=msg.match(/^(?:Enlightened agent |Resistance agent )?(.+?) destroyed a Resonator on (.+?) \(/);if(rM)return V(cleanA(rM[1]),'destroy',rM[2].trim(),0);
  return NE();
}
function V(agent,actionType,portal,mu){if(!agent||AGENT_BLACKLIST.has(agent.toLowerCase()))return NE();return{agent,actionType,portal,mu,isMyEvent:false,attacker:null,zone:null};}
function NE(){return{agent:null,actionType:'other',portal:null,mu:0,isMyEvent:false,attacker:null,zone:null};}
function cleanA(s){return(s||'').replace(/^(Enlightened agent |Resistance agent )/,'').trim();}
function extractZone(s){const m=s.match(/(\d{5})\s+([^,]+),/);if(m)return m[2].trim();const m2=s.match(/,\s*([^,]+),\s*Spain/i);if(m2)return m2[1].trim();return null;}
function buildMyDefenseStats(events){return events.filter(e=>e.isMyEvent&&e.actionType==='neutralize'&&e.portal).map(atk=>{const recap=events.find(e=>!e.isMyEvent&&e.agent===MY_AGENT&&e.ts>atk.ts&&e.portal===atk.portal&&(e.actionType==='capture'||e.actionType==='deploy'));return recap?{portal:atk.portal,attacker:atk.attacker,lostTs:atk.ts,recapTs:recap.ts,diffMin:Math.round((recap.ts-atk.ts)/60000)}:null;}).filter(Boolean);}

