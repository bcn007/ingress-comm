<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>INGRESS COMM · ENL</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600;700&display=swap');
:root{
  --bg:#050810;--bg2:#080d1a;--bg3:#0d1526;
  --enl:#00e5a0;--enl-dim:#004a35;
  --res:#00b4ff;--res-dim:#003a5a;
  --unk:#ff9f00;--unk-dim:#4a2d00;
  --danger:#ff3355;--danger-dim:#4a0015;
  --border:#1a2a3a;--text:#c8dde8;--text-dim:#4a6a7a;
  --gold:#ffd700;--silver:#c0c0c0;--bronze:#cd7f32;
  --spd-ok:#00e5a0;--spd-y:#ffe45c;--spd-o:#ff8c1a;--spd-r:#ff2d2d;
  --panel-w:40%;--map-w:60%;
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--text);font-family:'Rajdhani',sans-serif;display:flex;flex-direction:column;}

/* ── LOGIN ── */
.login-screen{position:fixed;inset:0;background:var(--bg);z-index:2000;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0;
  background-image:linear-gradient(rgba(0,229,160,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,229,160,.025) 1px,transparent 1px);
  background-size:40px 40px;}
.login-screen.hidden{display:none;}
.login-box{background:var(--bg2);border:1px solid var(--border);border-radius:14px;padding:40px 36px;width:90%;max-width:380px;text-align:center;}
.login-hex{margin:0 auto 20px;width:56px;height:56px;}
.login-hex svg{width:100%;height:100%;}
.login-title{font-family:'Orbitron',monospace;font-weight:900;font-size:18px;letter-spacing:4px;color:var(--enl);text-shadow:0 0 20px rgba(0,229,160,.4);margin-bottom:4px;}
.login-sub{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--text-dim);letter-spacing:2px;margin-bottom:28px;}
.login-input-wrap{position:relative;margin-bottom:14px;}
.login-input{width:100%;background:var(--bg3);border:1px solid var(--border);color:var(--text);font-family:'Share Tech Mono',monospace;font-size:14px;letter-spacing:3px;padding:13px 44px 13px 16px;border-radius:6px;outline:none;transition:border-color .2s;text-align:center;}
.login-input:focus{border-color:var(--enl);}
.login-eye{position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-dim);cursor:pointer;font-size:16px;padding:0;}
.login-eye:hover{color:var(--enl);}
.login-btn{width:100%;background:linear-gradient(135deg,var(--enl-dim),rgba(0,229,160,.2));border:1px solid var(--enl);color:var(--enl);font-family:'Orbitron',monospace;font-size:12px;letter-spacing:3px;padding:13px;border-radius:6px;cursor:pointer;transition:all .3s;box-shadow:0 0 16px rgba(0,229,160,.15);margin-bottom:12px;}
.login-btn:hover{background:var(--enl);color:var(--bg);}
.login-btn:active{transform:scale(.98);}
.login-error{font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--danger);height:16px;transition:opacity .2s;}
.login-error.hidden{opacity:0;}
.login-footer{font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--text-dim);margin-top:20px;letter-spacing:1px;}

/* ── HEADER ── */
.header{background:rgba(5,8,16,.97);border-bottom:1px solid var(--border);padding:10px 20px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;z-index:300;flex-shrink:0;}
.logo{display:flex;align-items:center;gap:10px;flex-shrink:0;}
.logo-hex{width:36px;height:36px;}
.logo-hex svg{width:100%;height:100%;}
.logo-title{font-family:'Orbitron',monospace;font-weight:900;font-size:15px;letter-spacing:3px;color:var(--enl);text-shadow:0 0 16px rgba(0,229,160,.4);}
.logo-sub{font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--text-dim);letter-spacing:2px;}
.pulse{width:7px;height:7px;border-radius:50%;background:var(--enl);box-shadow:0 0 6px var(--enl);animation:pulse 2s infinite;flex-shrink:0;}
@keyframes pulse{50%{opacity:.3;transform:scale(.8);}}
.status-lbl{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--text-dim);letter-spacing:1px;}

/* ── TIME RANGE SLIDER ── */
.time-range-wrap{flex:1;min-width:280px;display:flex;align-items:center;gap:10px;}
.time-range-inner{flex:1;position:relative;}
.time-range-labels{display:flex;justify-content:space-between;font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--text-dim);margin-bottom:3px;}
.time-range-track{position:relative;height:4px;background:var(--border);border-radius:2px;}
.time-range-fill{position:absolute;height:100%;background:var(--enl);border-radius:2px;pointer-events:none;}
.time-range-input{position:absolute;width:100%;height:4px;top:0;left:0;opacity:0;cursor:pointer;margin:0;}
.time-range-input::-webkit-slider-thumb{width:14px;height:14px;border-radius:50%;background:var(--enl);cursor:grab;-webkit-appearance:none;}
#sliderFrom{z-index:3;}
#sliderTo{z-index:4;}
.range-lbl{font-family:'Orbitron',monospace;font-size:9px;color:var(--enl);white-space:nowrap;}

/* ── MAIN LAYOUT ── */
.main{display:flex;flex:1;overflow:hidden;}

/* ── PANEL (left) ── */
.panel-col{width:var(--panel-w);flex-shrink:0;display:flex;flex-direction:column;border-right:1px solid var(--border);overflow:hidden;}
.panel-tabs{display:flex;gap:0;flex-shrink:0;border-bottom:1px solid var(--border);}
.ptab{background:var(--bg2);border:none;border-right:1px solid var(--border);color:var(--text-dim);font-family:'Share Tech Mono',monospace;font-size:10px;letter-spacing:1px;padding:8px 14px;cursor:pointer;transition:all .2s;flex:1;}
.ptab:hover{color:var(--text);}
.ptab.on{background:var(--bg);color:var(--enl);border-bottom:2px solid var(--enl);}
.panel-body{flex:1;overflow-y:auto;overflow-x:hidden;scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
.panel-inner{padding:16px;}
.tab-pane{display:none;}.tab-pane.on{display:block;}

/* ── MAP (right) ── */
.map-col{flex:1;position:relative;display:flex;flex-direction:column;}
#map{flex:1;}

/* MAP CONTROLS overlay */
.map-controls{position:absolute;top:10px;right:10px;z-index:400;display:flex;flex-direction:column;gap:6px;}
.map-btn{background:rgba(8,13,26,.92);border:1px solid var(--border);color:var(--text-dim);font-family:'Share Tech Mono',monospace;font-size:10px;padding:6px 10px;border-radius:4px;cursor:pointer;transition:all .2s;white-space:nowrap;}
.map-btn:hover{border-color:var(--enl);color:var(--enl);}
.map-btn.on{border-color:var(--enl);color:var(--enl);background:rgba(0,229,160,.06);}
.map-layer-panel{background:rgba(8,13,26,.95);border:1px solid var(--border);border-radius:6px;padding:10px;min-width:160px;}
.map-layer-row{display:flex;align-items:center;gap:8px;padding:4px 0;font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--text-dim);cursor:pointer;}
.map-layer-row:hover{color:var(--text);}
.map-layer-cb{accent-color:var(--enl);width:12px;height:12px;}

/* MAP info bar */
.map-infobar{flex-shrink:0;background:rgba(8,13,26,.95);border-top:1px solid var(--border);padding:6px 14px;display:flex;gap:16px;align-items:center;font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--text-dim);}
.map-infobar strong{color:var(--enl);}

/* ── IMPORT OVERLAY ── */
.import-overlay{position:fixed;inset:0;background:rgba(5,8,16,.96);z-index:800;display:flex;align-items:center;justify-content:center;}
.import-overlay.hidden{display:none;}
.import-box{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:40px;max-width:560px;width:90%;text-align:center;}
.drop-zone{border:2px dashed var(--border);border-radius:8px;padding:36px;cursor:pointer;position:relative;background:var(--bg3);transition:all .3s;margin-bottom:16px;}
.drop-zone:hover,.drop-zone.over{border-color:var(--enl);background:rgba(0,229,160,.04);box-shadow:0 0 24px rgba(0,229,160,.15);}
.drop-zone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;}
.drop-icon{font-size:34px;margin-bottom:10px;}
.drop-title{font-family:'Orbitron',monospace;font-size:13px;letter-spacing:3px;color:var(--enl);margin-bottom:6px;}
.drop-sub{font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--text-dim);}
.file-tags{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin-bottom:14px;}
.ftag{background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:4px 8px;font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--enl);display:flex;align-items:center;gap:6px;}
.ftag .rm{cursor:pointer;color:var(--text-dim);font-size:14px;}
.ftag .rm:hover{color:var(--danger);}
.btn-analyze{background:linear-gradient(135deg,var(--enl-dim),rgba(0,229,160,.18));border:1px solid var(--enl);color:var(--enl);font-family:'Orbitron',monospace;font-size:12px;letter-spacing:3px;padding:11px 30px;border-radius:4px;cursor:pointer;transition:all .3s;box-shadow:0 0 16px rgba(0,229,160,.2);}
.btn-analyze:hover{background:var(--enl);color:var(--bg);}
.btn-analyze:disabled{opacity:.3;cursor:not-allowed;}
.btn-reset{background:none;border:1px solid var(--border);color:var(--text-dim);font-family:'Share Tech Mono',monospace;font-size:10px;padding:6px 12px;border-radius:4px;cursor:pointer;margin-left:10px;}
.btn-reset:hover{border-color:var(--danger);color:var(--danger);}

/* ── LOADING ── */
.loading{display:none;position:fixed;inset:0;background:rgba(5,8,16,.92);z-index:999;align-items:center;justify-content:center;flex-direction:column;gap:18px;}
.loading.on{display:flex;}
.spinner{width:48px;height:48px;border:3px solid var(--border);border-top-color:var(--enl);border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
.loading-txt{font-family:'Orbitron',monospace;font-size:11px;letter-spacing:3px;color:var(--enl);animation:blink 1.2s infinite;}
@keyframes blink{50%{opacity:.2;}}

/* ── SECTION ── */
.s-title{font-family:'Orbitron',monospace;font-size:9px;letter-spacing:4px;color:var(--text-dim);text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:8px;}
.s-title::after{content:'';flex:1;height:1px;background:var(--border);}

/* ── KPI GRID ── */
.kpi-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px;}
.kpi{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:12px;position:relative;overflow:hidden;}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.kpi.enl::before{background:var(--enl);}
.kpi.res::before{background:var(--res);}
.kpi.unk::before{background:var(--unk);}
.kpi.danger::before{background:var(--danger);}
.kpi.neu::before{background:linear-gradient(90deg,var(--enl),var(--res));}
.kpi-lbl{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--text-dim);margin-bottom:4px;}
.kpi-val{font-family:'Orbitron',monospace;font-size:20px;font-weight:700;line-height:1;margin-bottom:2px;}
.kpi.enl .kpi-val{color:var(--enl);}
.kpi.res .kpi-val{color:var(--res);}
.kpi.unk .kpi-val{color:var(--unk);}
.kpi.danger .kpi-val{color:var(--danger);}
.kpi.neu .kpi-val{color:var(--text);}
.kpi-sub{font-size:10px;color:var(--text-dim);font-family:'Share Tech Mono',monospace;}

/* ── SORTABLE TABLE ── */
.tbl{width:100%;border-collapse:collapse;}
.tbl th{font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--text-dim);text-align:left;padding:6px 8px;border-bottom:1px solid var(--border);white-space:nowrap;cursor:pointer;user-select:none;}
.tbl th:hover{color:var(--text);}
.tbl th .sa{margin-left:3px;font-size:8px;}
.tbl th.sort-asc .sa::after{content:'▲';color:var(--enl);}
.tbl th.sort-desc .sa::after{content:'▼';color:var(--enl);}
.tbl th:not(.sort-asc):not(.sort-desc) .sa::after{content:'⇅';opacity:.4;}
.tbl td{padding:7px 8px;border-bottom:1px solid rgba(26,42,58,.3);vertical-align:middle;font-size:12px;}
.tbl tr:last-child td{border-bottom:none;}
.tbl tbody tr{cursor:pointer;transition:background .15s;}
.tbl tbody tr:hover td{background:rgba(0,229,160,.04);}
.tbl tbody tr.selected td{background:rgba(0,229,160,.08);}
.fbadge{display:inline-block;padding:1px 5px;border-radius:3px;font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:1px;}
.fbadge.enl{background:var(--enl-dim);color:var(--enl);border:1px solid rgba(0,229,160,.3);}
.fbadge.res{background:var(--res-dim);color:var(--res);border:1px solid rgba(0,180,255,.3);}
.fbadge.unk{background:var(--unk-dim);color:var(--unk);border:1px solid rgba(255,159,0,.3);}
.fbadge.me{background:rgba(0,229,160,.15);color:var(--enl);border:1px solid var(--enl);}
.mbar{display:inline-block;width:50px;height:3px;background:var(--bg2);border-radius:2px;overflow:hidden;vertical-align:middle;margin-left:4px;}
.mbar-f{height:100%;border-radius:2px;}
.spd{display:inline-block;padding:1px 5px;border-radius:3px;font-family:'Orbitron',monospace;font-size:9px;font-weight:700;}
.spd.ok{background:rgba(0,229,160,.12);color:var(--spd-ok);border:1px solid rgba(0,229,160,.2);}
.spd.y{background:rgba(255,228,92,.12);color:var(--spd-y);border:1px solid rgba(255,228,92,.2);}
.spd.o{background:rgba(255,140,26,.12);color:var(--spd-o);border:1px solid rgba(255,140,26,.2);}
.spd.r{background:rgba(255,45,45,.12);color:var(--spd-r);border:1px solid rgba(255,45,45,.2);}

/* ── ARCHETYPE ── */
.archetype{display:inline-flex;align-items:center;gap:4px;padding:2px 7px;border-radius:12px;font-family:'Orbitron',monospace;font-size:9px;font-weight:700;letter-spacing:.5px;border:1px solid;}
.arch-fielder{background:rgba(0,229,160,.08);color:var(--enl);border-color:rgba(0,229,160,.25);}
.arch-ninja{background:rgba(255,51,85,.08);color:var(--danger);border-color:rgba(255,51,85,.25);}
.arch-builder{background:rgba(0,180,255,.08);color:var(--res);border-color:rgba(0,180,255,.25);}
.arch-linker{background:rgba(255,159,0,.08);color:var(--unk);border-color:rgba(255,159,0,.25);}
.arch-defender{background:rgba(100,200,255,.08);color:#7adaff;border-color:rgba(100,200,255,.25);}
.arch-generalist{background:rgba(150,150,180,.08);color:#aabbd0;border-color:rgba(150,150,180,.2);}

/* ── PATTERN CHIPS ── */
.chip-wrap{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px;}
.chip{display:inline-flex;align-items:center;gap:3px;padding:3px 7px;border-radius:10px;font-family:'Share Tech Mono',monospace;font-size:9px;border:1px solid var(--border);background:var(--bg3);color:var(--text-dim);cursor:default;}
.tact-summary{font-family:'Share Tech Mono',monospace;font-size:10px;color:var(--text);line-height:1.6;padding:8px 10px;background:rgba(5,8,16,.6);border-radius:4px;border-left:2px solid var(--enl);margin-bottom:12px;}

/* ── BAR ── */
.bar-list{display:flex;flex-direction:column;gap:6px;}
.bar-row{display:flex;align-items:center;gap:8px;}
.bar-lbl{font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--text-dim);width:90px;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.bar-track{flex:1;height:12px;background:var(--bg3);border-radius:2px;overflow:hidden;}
.bar-fill{height:100%;border-radius:2px;transition:width .8s cubic-bezier(.4,0,.2,1);}
.bar-fill.enl{background:linear-gradient(90deg,var(--enl-dim),var(--enl));}
.bar-fill.res{background:linear-gradient(90deg,var(--res-dim),var(--res));}
.bar-fill.unk{background:linear-gradient(90deg,var(--unk-dim),var(--unk));}
.bar-fill.danger{background:linear-gradient(90deg,var(--danger-dim),var(--danger));}
.bar-val{font-family:'Orbitron',monospace;font-size:9px;width:44px;text-align:right;flex-shrink:0;}

/* ── TIMELINE ── */
.timeline-bars{display:flex;align-items:flex-end;gap:2px;height:60px;}
.t-bar{flex:1;min-width:2px;border-radius:1px 1px 0 0;position:relative;cursor:default;}
.t-bar:hover::after{content:attr(data-tip);position:absolute;bottom:calc(100% + 4px);left:50%;transform:translateX(-50%);background:var(--bg3);border:1px solid var(--border);padding:2px 6px;border-radius:3px;font-family:'Share Tech Mono',monospace;font-size:8px;white-space:nowrap;z-index:10;color:var(--text);pointer-events:none;}
.t-labels{display:flex;justify-content:space-between;padding:3px 0;font-family:'Share Tech Mono',monospace;font-size:8px;color:var(--text-dim);}

/* ── SESSIONS ── */
.session-list{display:flex;flex-direction:column;gap:6px;}
.session-card{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:10px 12px;cursor:pointer;transition:all .2s;position:relative;}
.session-card:hover{border-color:var(--enl);background:rgba(0,229,160,.04);}
.session-card.active{border-color:var(--enl);background:rgba(0,229,160,.07);}
.session-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:3px 0 0 3px;}
.session-card.enl::before{background:var(--enl);}
.session-card.res::before{background:var(--res);}
.sess-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
.sess-time{font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--text-dim);}
.sess-dur{font-family:'Orbitron',monospace;font-size:10px;color:var(--enl);}
.sess-stats{display:flex;gap:8px;font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--text-dim);}
.sess-arch{font-family:'Orbitron',monospace;font-size:8px;}
.sess-stat-val{color:var(--text);}
.sess-portals{font-size:10px;color:var(--text-dim);margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}

/* ── LOG ── */
.log-wrap{max-height:240px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
.log-row{display:flex;gap:8px;padding:4px 0;border-bottom:1px solid rgba(26,42,58,.3);font-family:'Share Tech Mono',monospace;font-size:10px;line-height:1.4;}
.log-time{color:var(--text-dim);flex-shrink:0;width:90px;font-size:9px;}
.log-fac{flex-shrink:0;width:28px;text-align:center;}
.log-msg{flex:1;color:var(--text);}

/* ── ATTACK ── */
.attack-panel{background:rgba(255,51,85,.05);border:1px solid rgba(255,51,85,.18);border-radius:6px;padding:12px;margin-bottom:12px;}
.attacker-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;}
.attacker-name{font-family:'Orbitron',monospace;font-size:11px;color:var(--res);width:130px;flex-shrink:0;}
.attacker-num{font-family:'Orbitron',monospace;font-size:12px;font-weight:700;color:var(--danger);}
.def-row{display:flex;align-items:center;justify-content:space-between;padding:5px 8px;background:var(--bg3);border-radius:3px;border:1px solid var(--border);margin-bottom:4px;}
.def-portal{font-size:11px;color:var(--text);flex:1;}
.def-time{font-family:'Orbitron',monospace;font-size:10px;color:var(--unk);}

/* ── SPEED ── */
.speed-panel{background:rgba(0,229,160,.03);border:1px solid rgba(0,229,160,.1);border-radius:6px;padding:12px;margin-bottom:12px;}
.seg-row{display:flex;align-items:flex-start;gap:8px;padding:6px 0;border-bottom:1px solid rgba(26,42,58,.3);}
.seg-row:last-child{border-bottom:none;}
.seg-main{flex:1;font-size:11px;}
.seg-portals{color:var(--text);font-weight:600;margin-bottom:2px;}
.seg-meta{font-family:'Share Tech Mono',monospace;font-size:9px;color:var(--text-dim);}
.seg-kmh{font-family:'Orbitron',monospace;font-size:12px;font-weight:700;flex-shrink:0;text-align:right;min-width:55px;}

/* ── HOUR ── */
.hour-chart{display:flex;align-items:flex-end;gap:2px;height:50px;margin-top:6px;}
.h-bar{flex:1;min-width:5px;border-radius:1px 1px 0 0;position:relative;cursor:default;}
.h-bar:hover::after{content:attr(data-tip);position:absolute;bottom:calc(100% + 3px);left:50%;transform:translateX(-50%);background:var(--bg3);border:1px solid var(--border);padding:2px 6px;border-radius:3px;font-family:'Share Tech Mono',monospace;font-size:8px;white-space:nowrap;z-index:10;color:var(--text);}
