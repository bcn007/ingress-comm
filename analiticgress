function computePatterns(P,allEvents){
  const pats={};const total=P.count||1;
  const fieldR=(P.actions.field||0)/total,deployR=(P.actions.deploy||0)/total,linkR=(P.actions.link||0)/total,destroyR=(P.actions.destroy||0)/total,capR=(P.actions.capture||0)/total;
  const muPerField=P.actions.field>0?P.totalMU/P.actions.field:0;
  let arch='generalist';
  if(fieldR>0.15&&muPerField>50) arch='fielder';
  else if(destroyR>0.25&&capR>0.1) arch='ninja';
  else if(deployR>0.45&&fieldR<0.1) arch='builder';
  else if(linkR>0.3&&fieldR<0.08) arch='linker';
  else if(deployR>0.3&&destroyR<0.05&&Object.keys(P.deployedPortals||{}).length<10) arch='defender';
  P.archetype=arch;P.archetypeData=archetypeMap[arch];
  // Time window
  const hT=Array.from({length:24},(_,h)=>P.hourActivity[h]||0);
  const hSum=hT.reduce((a,b)=>a+b,0)||1;
  const morn=hT.slice(6,10).reduce((a,b)=>a+b,0)/hSum,day=hT.slice(10,18).reduce((a,b)=>a+b,0)/hSum,eve=hT.slice(18,22).reduce((a,b)=>a+b,0)/hSum,ngt=[...hT.slice(22),...hT.slice(0,4)].reduce((a,b)=>a+b,0)/hSum;
  const maxS=Math.max(morn,day,eve,ngt);
  let tL='',tI='';
  if(maxS===morn){tL='Madrugador';tI='🌅';}else if(maxS===day){tL='Diurno';tI='☀️';}else if(maxS===eve){tL='Vespertino';tI='🌆';}else{tL='Nocturno';tI='🌙';}
  const wkA=(P.dowActivity[0]||0)+(P.dowActivity[6]||0),wkdA=[1,2,3,4,5].reduce((a,d)=>a+(P.dowActivity[d]||0),0);
  if(P.daysActive.size>2&&wkA/Math.max(wkA+wkdA,1)>0.55)tL='Fin de semana';
  pats.timeWindow={label:`${tI} ${tL}`,desc:`Concentra actividad en horario ${tL.toLowerCase()}.`,icon:tI};
  // Gini
  const freqs=Object.values(P.portalFreq||{}).sort((a,b)=>a-b);let gini=0;
  if(freqs.length>1){const n=freqs.length,sum=freqs.reduce((a,b)=>a+b,0)||1;freqs.forEach((f,i)=>{gini+=((2*(i+1)-n-1)*f);});gini=Math.abs(gini/(n*sum));}
  let trL='',trI='';
  if(gini>0.65){trL='Territorial';trI='📍';}else if(gini>0.35){trL='Semi-territorial';trI='🗺️';}else{trL='Nómada';trI='🚀';}
  pats.territoriality={label:`${trI} ${trL}`,desc:gini>0.65?'Opera repetidamente en los mismos portales.':gini>0.35?'Combina zona habitual con exploración.':'Gran variedad de portales. Movilidad alta.',gini};
  // Field eff
  if(P.actions.field>0){let eL='',eI='';if(muPerField>2000){eL='Macro-fielder';eI='🌐';}else if(muPerField>300){eL='Fielder medio';eI='🔺';}else{eL='Micro-fielder';eI='🔹';}pats.fieldEff={label:`${eI} ${eL}`,desc:`${Math.round(muPerField).toLocaleString()} MU/campo.`,icon:eI};}
  // Ninja
  let ninjaSeq=0;const ptLines={};
  (P.rawEvents||[]).forEach(ev=>{if(!ev.portal)return;if(!ptLines[ev.portal])ptLines[ev.portal]=[];ptLines[ev.portal].push(ev);});
  Object.values(ptLines).forEach(evs=>{evs.sort((a,b)=>a.ts-b.ts);for(let i=0;i<evs.length-2;i++){const a=evs[i],b=evs[i+1],c=evs[i+2];if(c.ts-a.ts>10*60*1000)continue;if(a.actionType==='destroy'&&b.actionType==='capture'&&(c.actionType==='deploy'||c.actionType==='link'||c.actionType==='field'))ninjaSeq++;}});
  const onlyDest=(P.actions.destroy||0)>3&&(P.actions.capture||0)<(P.actions.destroy||0)*0.3;
  if(ninjaSeq>=3)pats.ninjaPattern={label:'⚡ Ninja coordinado',desc:`${ninjaSeq} secuencias destroy→capture→build en <10min.`,count:ninjaSeq};
  else if(onlyDest)pats.ninjaPattern={label:'💥 Puro atacante',desc:`Alto ratio destrucciones sin reconstrucción posterior.`};
  // Consistency
  const rMs=(P.lastActiveTs||0)-(P.firstTs||0),rDays=Math.max(1,rMs/(1000*3600*24)),aPct=P.daysActive.size/rDays;
  let cL='',cI='',cD='';
  if(aPct>0.6){cL='Diario';cI='📅';cD='Juega prácticamente todos los días.';}else if(aPct>0.2){cL='Regular';cI='🗓️';cD='Actividad frecuente pero no diaria.';}else{cL='Casual';cI='💤';cD='Aparece esporádicamente.';}
  const sessL=P.avgSessionMin>120?'Maratoniano':P.avgSessionMin>30?'Sesiones medias':'Sesiones cortas';
  pats.consistency={label:`${cI} ${cL} · ${sessL}`,desc:`${cD} Sesión media ${P.avgSessionMin}min.`,icon:cI};
  // Guardian
  const sP=Object.entries(P.portalFreq||{}).sort((a,b)=>b[1]-a[1]);
  const top3=sP.slice(0,3).reduce((s,[,n])=>s+n,0);const top3P=total>0?top3/total:0;
  if(top3P>0.3&&sP.length>0)pats.guardian={label:`🏰 Guardián`,desc:`${Math.round(top3P*100)}% de acciones en ≤3 portales. Principal: "${sP[0][0]}".`};
