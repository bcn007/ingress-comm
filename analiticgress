<script>
// ============================================================
// CONFIG
// ============================================================
const MY_AGENT='HaidaMahalo';
const SESSION_GAP=4*60*60*1000;
const AGENT_BLACKLIST=new Set(['agent','your','enlightened','resistance','machina','unknown','a','an','the','enlightened agent','resistance agent']);

// ← PEGA AQUÍ LA URL DEL APPS SCRIPT DESPUÉS DE PUBLICARLO
const APPS_SCRIPT_URL='https://script.google.com/macros/s/AKfycby7K7JIdVRHOU7f2K37pYDd0wEFYcn0dHiag0v81lmjljdoG6g-3zbx5vOaYLng9Ih7/exec';

// ============================================================
// GLOBAL STATE
// ============================================================
let G=null;
let GF=null;
let activePlayer=null;
let activeSession=null;
let agentFilter='all';
const sortState={};
let map=null;
const layers={portals:null,player:null,session:null,mine:null,context:null};
const layerVisible={portals:true,player:true,session:true,mine:true,context:false};
let rangeMin=0,rangeMax=1000,tsMin=0,tsMax=1;

// ============================================================
// AUTH
// ============================================================
const PWD_HASH='0cd6207782bd0ac56b14d31c78614d2968bf04ff8a087e999bba56a515383844';

async function sha256(str){
  const buf=await crypto.subtle.digest('SHA-256',new TextEncoder().encode(str));
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

async function doLogin(){
  const val=document.getElementById('loginInput').value.trim();
  if(!val) return;
  const btn=document.getElementById('loginBtn');
  btn.textContent='···';btn.disabled=true;
  const hash=await sha256(val);
  if(hash===PWD_HASH){
    sessionStorage.setItem('ingress_auth','1');
    document.getElementById('loginScreen').classList.add('hidden');
    btn.textContent='▶ ACCEDER';btn.disabled=false;
    loadFromDrive();
  }else{
    const err=document.getElementById('loginError');
    err.classList.remove('hidden');
    document.getElementById('loginInput').value='';
    document.getElementById('loginInput').focus();
    setTimeout(()=>err.classList.add('hidden'),2500);
    btn.textContent='▶ ACCEDER';btn.disabled=false;
  }
}

function toggleLoginEye(){
  const inp=document.getElementById('loginInput');
  const eye=document.getElementById('loginEye');
  if(inp.type==='password'){inp.type='text';eye.textContent='🙈';}
  else{inp.type='password';eye.textContent='👁';}
}

document.getElementById('loginInput').addEventListener('keydown',e=>{if(e.key==='Enter')doLogin();});

// Check if already authenticated this session
if(sessionStorage.getItem('ingress_auth')==='1'){
  document.getElementById('loginScreen').classList.add('hidden');
  // loadFromDrive() will be called after DOM ready
  window.addEventListener('load',()=>loadFromDrive());
}

// ============================================================
// DRIVE LOADER
// ============================================================
async function loadFromDrive(){
  if(!APPS_SCRIPT_URL){
    showDriveError('APPS_SCRIPT_URL no configurada. Edita el dashboard y pega la URL del script.');
    return;
  }

  setLoadingMsg('CONECTANDO CON DRIVE...');
  document.getElementById('loading').classList.add('on');

  try{
    const res=await fetch(APPS_SCRIPT_URL);
    if(!res.ok) throw new Error('HTTP '+res.status);
    const data=await res.json();
    if(!data.ok) throw new Error(data.error||'Error desconocido del script');
    if(!data.files||!data.files.length) throw new Error('La carpeta de Drive está vacía. Sube al menos un archivo .txt.');

    setLoadingMsg(`PROCESANDO ${data.files.length} ARCHIVOS...`);
    await tick();

    const texts=data.files.map(f=>f.content);
    const names=data.files.map(f=>f.name);

    G=parseAll(texts,names);
    initTimeRange();
    applyTimeFilter();

    document.getElementById('timeRangeWrap').style.display='flex';
    document.getElementById('btnReset').style.display='inline-block';
    document.getElementById('statusLbl').textContent=`${data.files.length} archivos · ${G.events.length.toLocaleString()} eventos`;
    initMap();

  }catch(e){
    console.error(e);
    showDriveError(e.message);
  }

  document.getElementById('loading').classList.remove('on');
}

function setLoadingMsg(msg){
  document.getElementById('loadingTxt').textContent=msg;
}

function showDriveError(msg){
  document.getElementById('loading').classList.remove('on');
  // Show error inside the import overlay as fallback
  const ov=document.getElementById('importOverlay');
  ov.classList.remove('hidden');
  ov.innerHTML=`
    <div class="import-box" style="text-align:center">
      <div style="font-size:36px;margin-bottom:16px">⚠</div>
      <div style="font-family:'Orbitron',monospace;font-size:13px;letter-spacing:2px;color:var(--danger);margin-bottom:12px">ERROR AL CARGAR DATOS</div>
      <div style="font-family:'Share Tech Mono',monospace;font-size:11px;color:var(--text-dim);margin-bottom:20px;line-height:1.6">${esc(msg)}</div>
      <button class="btn-analyze" onclick="loadFromDrive()">↺ REINTENTAR</button>
    </div>`;
}

document.getElementById('btnReset').addEventListener('click',()=>{
  G=null;GF=null;activePlayer=null;activeSession=null;
  document.getElementById('timeRangeWrap').style.display='none';
  document.getElementById('btnReset').style.display='none';
  clearMapLayers();
  loadFromDrive();
});

const tick=()=>new Promise(r=>setTimeout(r,30));

// ============================================================
// TIME RANGE
// ============================================================
function initTimeRange(){
  const evTs=G.events.map(e=>e.ts).filter(Boolean);
  tsMin=Math.min(...evTs);
  tsMax=Math.max(...evTs);
  rangeMin=0;rangeMax=1000;
  updateRangeUI();
  setupSliders();
}

function setupSliders(){
  const sFrom=document.getElementById('sliderFrom');
  const sTo=document.getElementById('sliderTo');
  function onInput(){
    let a=parseInt(sFrom.value),b=parseInt(sTo.value);
    if(a>b-10){if(this===sFrom)a=b-10;else b=a+10;}
    sFrom.value=a;sTo.value=b;
    rangeMin=a;rangeMax=b;
    updateRangeUI();
    applyTimeFilter();
  }
  sFrom.oninput=onInput;
  sTo.oninput=onInput;
}

function updateRangeUI(){
  const fill=document.getElementById('rangeFill');
  fill.style.left=(rangeMin/10)+'%';
  fill.style.width=((rangeMax-rangeMin)/10)+'%';
  const tsA=tsMin+(rangeMin/1000)*(tsMax-tsMin);
  const tsB=tsMin+(rangeMax/1000)*(tsMax-tsMin);
  document.getElementById('rangeFrom').textContent=fmtDateShort(tsA);
  document.getElementById('rangeTo').textContent=fmtDateShort(tsB);
}

function applyTimeFilter(){
  if(!G) return;
  const tsA=tsMin+(rangeMin/1000)*(tsMax-tsMin);
  const tsB=tsMin+(rangeMax/1000)*(tsMax-tsMin);
  GF=filterDataset(G,tsA,tsB);
  renderAll();
  refreshMap();
}

function filterDataset(data,tsA,tsB){
  const events=data.events.filter(e=>e.ts>=tsA&&e.ts<=tsB);
  // Recompute aggregates on filtered events
  const players={},portals={};
  const acCounts={capture:0,deploy:0,link:0,field:0,destroy:0,destroyLink:0,destroyField:0,attack:0,neutralize:0,other:0};
  const facCounts={ENL:0,RES:0,UNK:0};
  let totalMU=0,enlMU=0,resMU=0;
  const hourBuckets={};
  const myAttacks={};

  // Build player subset from full player list, filtering rawEvents
  data.players.forEach(P=>{
    const filteredEvents=P.rawEvents.filter(e=>e.ts>=tsA&&e.ts<=tsB);
    if(!filteredEvents.length) return;
    // Recompute quick stats
    const actions={capture:0,deploy:0,link:0,field:0,destroy:0,destroyLink:0,destroyField:0,other:0};
    let mu=0;
    const portalFreq={},hourActivity={},zones={},deployedPortals={},dowActivity={};
    const daysActive=new Set();
    const eventKinds={presence:0,attack:0,unknown:0};
    filteredEvents.forEach(ev=>{
      actions[ev.actionType]=(actions[ev.actionType]||0)+1;
      if(ev.portal) portalFreq[ev.portal]=(portalFreq[ev.portal]||0)+1;
      const h=new Date(ev.ts).getHours();
      hourActivity[h]=(hourActivity[h]||0)+1;
      const dow=new Date(ev.ts).getDay();
      dowActivity[dow]=(dowActivity[dow]||0)+1;
      daysActive.add(new Date(ev.ts).toISOString().slice(0,10));
      if(ev.actionType==='deploy'||ev.actionType==='capture') if(ev.portal) deployedPortals[ev.portal]=(deployedPortals[ev.portal]||0)+1;
      eventKinds[ev.kind]=(eventKinds[ev.kind]||0)+1;
    });
    // Filter sessions
    const sessions=P.sessions.filter(s=>s.startTs>=tsA&&s.startTs<=tsB);
    const FP=Object.assign({},P,{
      rawEvents:filteredEvents,count:filteredEvents.length,
      actions,portalFreq,hourActivity,dowActivity,zones:P.zones,
      deployedPortals,daysActive,eventKinds,sessions,
      totalMU:filteredEvents.reduce((s,e)=>s+(e.mu||0),0)
    });
    // Recompute speed from filtered presence events
    computeSpeedSegments(FP);
    computePatterns(FP,events);
    players[P.name]=FP;
  });

  events.forEach(ev=>{
    facCounts[ev.faction]=(facCounts[ev.faction]||0)+1;
    if(ev.portal&&!ev.isMyEvent){
      if(!portals[ev.portal]) portals[ev.portal]={name:ev.portal,count:0,factions:{},lat:ev.lat,lng:ev.lng};
      portals[ev.portal].count++;
      portals[ev.portal].factions[ev.faction]=(portals[ev.portal].factions[ev.faction]||0)+1;
      if(ev.lat&&!portals[ev.portal].lat){portals[ev.portal].lat=ev.lat;portals[ev.portal].lng=ev.lng;}
    }
    acCounts[ev.actionType]=(acCounts[ev.actionType]||0)+1;
    if(ev.mu>0){totalMU+=ev.mu;if(ev.faction==='ENL')enlMU+=ev.mu;if(ev.faction==='RES')resMU+=ev.mu;}
    if(ev.ts){const d=new Date(ev.ts);const k=`${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}h`;hourBuckets[k]=(hourBuckets[k]||0)+1;}
    if(ev.isMyEvent&&ev.attacker){
      if(!myAttacks[ev.attacker])myAttacks[ev.attacker]={portalsHit:{},linksDestroyed:0,fieldsDestroyed:0,timestamps:[],portalsNeutralized:0};
      const A=myAttacks[ev.attacker];A.timestamps.push(ev.ts);
      if(ev.actionType==='attack')A.portalsHit[ev.portal]=(A.portalsHit[ev.portal]||0)+1;
      if(ev.actionType==='neutralize')A.portalsNeutralized++;
      if(ev.actionType==='destroyLink')A.linksDestroyed++;
    }
  });

  // Cross-coordination on filtered
  const pList=Object.values(players).sort((a,b)=>b.count-a.count);
  computeCoordination(pList,events);

  return{
    events,
    players:pList,
    portals:Object.values(portals).sort((a,b)=>b.count-a.count),
    acCounts,facCounts,totalMU,enlMU,resMU,
    hourBuckets,myAttacks,
    meDefenseStats:buildMyDefenseStats(events),
    meta:data.meta
  };
}

